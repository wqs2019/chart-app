{
  "expo": {
    "name": "RN CLI Template",
    "slug": "rn-cli-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rnclitemplate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-apple-authentication",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "允许访问相册，用于给榜单记录添加图片和视频附件。",
          "cameraPermission": "允许使用相机，用于给榜单记录拍摄图片和视频附件。",
          "microphonePermission": "允许使用麦克风，用于录制带声音的视频附件。"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.traval.chartapp",
      "appleTeamId": "592UG636F5",
      "usesAppleSignIn": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.traval.chartapp"
    }
  }
}
