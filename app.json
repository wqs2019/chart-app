{
  "expo": {
    "name": "RN CLI Template",
    "slug": "rn-cli-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rnclitemplate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": ["expo-apple-authentication"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.traval.chartapp",
      "appleTeamId": "592UG636F5",
      "usesAppleSignIn": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.traval.chartapp"
    }
  }
}
